#!/usr/bin/env python3
"""
Validate a CITATION.cff file using cffconvert.

Usage:
  scripts/validate_cff [CITATION.cff path]

Requires: pip install cffconvert
"""

import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parent.parent
CFF_PATH = REPO_ROOT / "CITATION.cff"


def validate(cff_path: Path = CFF_PATH) -> bool:
    if not cff_path.exists():
        print(f"ERROR: {cff_path} not found")
        return False

    result = subprocess.run(
        ["cffconvert", "--validate", "-i", str(cff_path)],
        capture_output=True,
        text=True,
    )
    if result.returncode == 0:
        print(f"✓ {cff_path} is valid")
        return True

    print(f"✗ {cff_path} is INVALID:")
    print(result.stderr or result.stdout)
    return False


if __name__ == "__main__":
    cff_path = Path(sys.argv[1]) if len(sys.argv) > 1 else CFF_PATH
    sys.exit(0 if validate(cff_path) else 1)